# Home Assistant URL (must be reachable from this app)
# Local dev: http://homeassistant.local:8123
# Railway: use Nabu Casa remote URL or your public HTTPS URL — NOT homeassistant.local
HA_URL=http://homeassistant.local:8123

# Long-lived access token from HA Profile → Security → Long-Lived Access Tokens
HA_TOKEN=your_token_here
